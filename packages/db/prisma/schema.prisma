generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────

enum UserRole {
  CLINICIAN
  PARTICIPANT
  ADMIN
}

enum Cadence {
  WEEKLY
  BIWEEKLY
  SELF_PACED
}

enum EnrollmentMethod {
  INVITE
  LINK
  CODE
}

enum SessionType {
  ONE_ON_ONE
  GROUP
  SELF_PACED
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UnlockRule {
  SEQUENTIAL
  MANUAL
  TIME_BASED
}

enum PartType {
  TEXT
  VIDEO
  STRATEGY_CARDS
  JOURNAL_PROMPT
  CHECKLIST
  RESOURCE_LINK
  DIVIDER
  HOMEWORK
  ASSESSMENT
  INTAKE_FORM
  SMART_GOALS
  STYLED_CONTENT
}

enum EnrollmentStatus {
  INVITED
  ACTIVE
  PAUSED
  COMPLETED
  DROPPED
}

enum ModuleProgressStatus {
  LOCKED
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

enum PartProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum TaskStatus {
  TODO
  DONE
  ARCHIVED
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum TaskSourceType {
  MANUAL
  HOMEWORK
  CLINICIAN_PUSH
  SESSION
}

enum EventType {
  TIME_BLOCK
  SESSION
  EXTERNAL_SYNC
  CATCH_UP
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationCategory {
  MORNING_CHECKIN
  HOMEWORK
  SESSION
  TASK
  WEEKLY_REVIEW
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  CUSTOM
}

enum TrackerFieldType {
  SCALE
  NUMBER
  YES_NO
  MULTI_CHECK
  FREE_TEXT
  TIME
}

enum HomeworkInstanceStatus {
  PENDING
  COMPLETED
  SKIPPED
  MISSED
}

enum ProviderType {
  THERAPIST
  PSYCHIATRIST
  PSYCHOLOGIST
  COUNSELOR
  PSYCH_NP
  COACH
  OTHER
}

// ── Practices ─────────────────────────────────────────

enum PracticeRole {
  OWNER
  CLINICIAN
}

model Practice {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships PracticeMembership[]
  programs    Program[]            @relation("PracticePrograms")

  @@map("practices")
}

model PracticeMembership {
  id           String       @id @default(cuid())
  practiceId   String
  practice     Practice     @relation(fields: [practiceId], references: [id])
  clinicianId  String
  clinician    ClinicianProfile @relation(fields: [clinicianId], references: [id])
  role         PracticeRole @default(CLINICIAN)
  joinedAt     DateTime     @default(now())

  @@unique([practiceId, clinicianId])
  @@index([practiceId])
  @@index([clinicianId])
  @@map("practice_memberships")
}

// ── Users & Auth ───────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  firstName    String
  lastName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pushToken    String?
  pushTokenUpdatedAt DateTime?

  clinicianProfile      ClinicianProfile?
  participantProfile    ParticipantProfile?
  notificationPreferences NotificationPreference[]

  rtmEngagementEvents  RtmEngagementEvent[]
  rtmEnrollmentsAsClient RtmEnrollment[]      @relation("RtmClient")
  rtmBillingPeriodsAsClient RtmBillingPeriod[] @relation("RtmBillingClient")
  rtmTimeLogsAsClient  RtmClinicianTimeLog[]  @relation("RtmTimeLogClient")
  clientConfigs        ClientConfig[]         @relation("ClientConfigs")
  clinicianClients     ClinicianClient[]      @relation("ClinicianClientUser")

  @@map("users")
}

model ClinicianProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
  practiceName String?
  licenseType  String?
  bio          String?
  timezone     String  @default("America/New_York")

  programs    Program[]
  memberships PracticeMembership[]

  rtmEnrollments    RtmEnrollment[]
  rtmBillingPeriods RtmBillingPeriod[]
  rtmTimeLogs       RtmClinicianTimeLog[]
  billingProfile    ClinicianBillingProfile?
  config            ClinicianConfig?
  clientConfigs     ClientConfig[]   @relation("ClinicianClientConfigs")
  clients           ClinicianClient[]

  @@map("clinician_profiles")
}

model ParticipantProfile {
  id                   String  @id @default(cuid())
  userId               String  @unique
  user                 User    @relation(fields: [userId], references: [id])
  timezone             String  @default("America/New_York")
  onboardingCompleted  Boolean @default(false)

  enrollments    Enrollment[]
  tasks          Task[]
  calendarEvents CalendarEvent[]
  journalEntries JournalEntry[]

  @@map("participant_profiles")
}

// ── Programs & Content ─────────────────────────────────

model Program {
  id               String           @id @default(cuid())
  clinicianId      String
  clinician        ClinicianProfile @relation(fields: [clinicianId], references: [id])
  practiceId       String?
  practice         Practice?        @relation("PracticePrograms", fields: [practiceId], references: [id])
  title            String
  description      String?
  category         String?
  durationWeeks    Int?
  coverImageUrl    String?
  cadence          Cadence          @default(WEEKLY)
  enrollmentMethod EnrollmentMethod @default(INVITE)
  enrollmentCode   String?          @unique
  sessionType      SessionType      @default(ONE_ON_ONE)
  followUpCount    Int              @default(0)
  isTemplate       Boolean          @default(false)
  templateSourceId String?
  templateSource   Program?         @relation("ProgramTemplate", fields: [templateSourceId], references: [id])
  clones           Program[]        @relation("ProgramTemplate")
  status           ProgramStatus    @default(DRAFT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  modules       Module[]
  enrollments   Enrollment[]
  dailyTrackers DailyTracker[]

  @@index([practiceId])
  @@map("programs")
}

model Module {
  id               String     @id @default(cuid())
  programId        String
  program          Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  title            String
  subtitle         String?
  summary          String?
  estimatedMinutes Int?
  sortOrder        Int
  unlockRule       UnlockRule @default(SEQUENTIAL)
  unlockDelayDays  Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  parts           Part[]
  moduleProgress  ModuleProgress[]
  currentEnrollments Enrollment[] @relation("CurrentModule")
  completedSessions  Session[]    @relation("CompletedModule")

  @@map("modules")
}

model Part {
  id         String   @id @default(cuid())
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type       PartType
  title      String
  sortOrder  Int
  isRequired Boolean  @default(true)
  content    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  partProgress      PartProgress[]
  journalEntries    JournalEntry[] @relation("PromptPart")
  homeworkInstances HomeworkInstance[]

  @@map("parts")
}

// ── Enrollment & Progress ──────────────────────────────

model Enrollment {
  id              String           @id @default(cuid())
  participantId   String
  participant     ParticipantProfile @relation(fields: [participantId], references: [id])
  programId       String
  program         Program          @relation(fields: [programId], references: [id])
  status          EnrollmentStatus @default(INVITED)
  currentModuleId String?
  currentModule   Module?          @relation("CurrentModule", fields: [currentModuleId], references: [id])
  enrolledAt      DateTime         @default(now())
  completedAt     DateTime?

  moduleProgress      ModuleProgress[]
  partProgress        PartProgress[]
  sessions            Session[]
  homeworkInstances   HomeworkInstance[]
  dailyTrackers       DailyTracker[]
  rtmEngagementEvents RtmEngagementEvent[]
  rtmEnrollments      RtmEnrollment[]
  rtmBillingPeriods   RtmBillingPeriod[]

  @@map("enrollments")
}

model ModuleProgress {
  id           String               @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment           @relation(fields: [enrollmentId], references: [id])
  moduleId     String
  module       Module               @relation(fields: [moduleId], references: [id])
  status       ModuleProgressStatus @default(LOCKED)
  unlockedAt   DateTime?
  completedAt  DateTime?
  customUnlock Boolean              @default(false)

  @@unique([enrollmentId, moduleId])
  @@index([enrollmentId])
  @@map("module_progress")
}

model PartProgress {
  id           String             @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment         @relation(fields: [enrollmentId], references: [id])
  partId       String
  part         Part               @relation(fields: [partId], references: [id])
  status       PartProgressStatus @default(NOT_STARTED)
  completedAt  DateTime?
  responseData Json?

  @@unique([enrollmentId, partId])
  @@index([enrollmentId])
  @@map("part_progress")
}

// ── Steady System ──────────────────────────────────────

model Task {
  id               String          @id @default(cuid())
  participantId    String
  participant      ParticipantProfile @relation(fields: [participantId], references: [id])
  title            String
  description      String?
  estimatedMinutes Int?
  dueDate          DateTime?
  energyLevel      EnergyLevel?
  category         String?
  isRecurring      Boolean         @default(false)
  recurrenceRule   Json?
  status           TaskStatus      @default(TODO)
  completedAt      DateTime?
  sourceType       TaskSourceType?
  sourceId         String?
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  calendarEvents CalendarEvent[]

  @@index([participantId])
  @@map("tasks")
}

model CalendarEvent {
  id                 String    @id @default(cuid())
  participantId      String
  participant        ParticipantProfile @relation(fields: [participantId], references: [id])
  title              String
  startTime          DateTime
  endTime            DateTime
  taskId             String?
  task               Task?     @relation(fields: [taskId], references: [id])
  eventType          EventType
  color              String?
  externalCalendarId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("calendar_events")
}

model JournalEntry {
  id                    String              @id @default(cuid())
  participantId         String
  participant           ParticipantProfile  @relation(fields: [participantId], references: [id])
  entryDate             DateTime            @db.Date
  promptPartId          String?
  promptPart            Part?               @relation("PromptPart", fields: [promptPartId], references: [id])
  responses             Json?
  freeformContent       String?
  regulationScore       Int?
  isSharedWithClinician Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([participantId, entryDate])
  @@map("journal_entries")
}

// ── Sessions ───────────────────────────────────────────

model Session {
  id                 String        @id @default(cuid())
  enrollmentId       String
  enrollment         Enrollment    @relation(fields: [enrollmentId], references: [id])
  scheduledAt        DateTime
  videoCallUrl       String?
  status             SessionStatus @default(SCHEDULED)
  clinicianNotes     String?
  participantSummary String?
  moduleCompletedId  String?
  moduleCompleted    Module?       @relation("CompletedModule", fields: [moduleCompletedId], references: [id])
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([scheduledAt])
  @@map("sessions")
}

// ── Notifications ──────────────────────────────────────

model NotificationPreference {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  category       NotificationCategory
  enabled        Boolean              @default(true)
  preferredTime  String?
  customSettings Json?

  @@unique([userId, category])
  @@map("notification_preferences")
}

// ── Homework Instances (Recurring) ────────────────────

model HomeworkInstance {
  id           String                 @id @default(cuid())
  partId       String
  part         Part                   @relation(fields: [partId], references: [id], onDelete: Cascade)
  enrollmentId String
  enrollment   Enrollment             @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  dueDate      DateTime               @db.Date
  status       HomeworkInstanceStatus  @default(PENDING)
  completedAt  DateTime?
  response     Json?
  createdAt    DateTime               @default(now())

  @@unique([partId, enrollmentId, dueDate])
  @@index([enrollmentId])
  @@index([partId])
  @@index([dueDate])
  @@map("homework_instances")
}

// ── Daily Trackers ────────────────────────────────────

model DailyTracker {
  id           String       @id @default(cuid())
  programId    String?
  program      Program?     @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrollmentId String?
  enrollment   Enrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  createdById  String
  name         String
  description  String?
  reminderTime String       @default("20:00")
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  fields  DailyTrackerField[]
  entries DailyTrackerEntry[]

  @@index([programId])
  @@index([enrollmentId])
  @@map("daily_trackers")
}

model DailyTrackerField {
  id         String           @id @default(cuid())
  trackerId  String
  tracker    DailyTracker     @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  label      String
  fieldType  TrackerFieldType
  options    Json?
  sortOrder  Int
  isRequired Boolean          @default(true)

  @@index([trackerId])
  @@map("daily_tracker_fields")
}

model DailyTrackerEntry {
  id          String       @id @default(cuid())
  trackerId   String
  tracker     DailyTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  userId      String
  date        DateTime     @db.Date
  responses   Json
  completedAt DateTime
  createdAt   DateTime     @default(now())

  @@unique([trackerId, userId, date])
  @@index([trackerId])
  @@index([userId])
  @@index([date])
  @@map("daily_tracker_entries")
}

// ── RTM (Remote Therapeutic Monitoring) ──────────────

enum RtmEventType {
  DAILY_TRACKER_COMPLETED
  HOMEWORK_COMPLETED
  ASSESSMENT_COMPLETED
  STRATEGY_CARD_VIEWED
  JOURNAL_ENTRY_CREATED
  RESOURCE_VIEWED
  APP_OPENED
  MESSAGE_SENT
}

enum RtmPeriodStatus {
  ACTIVE
  THRESHOLD_MET
  BILLED
  EXPIRED
}

enum RtmBillingTier {
  NONE
  SHORT_PERIOD
  FULL_PERIOD
}

enum RtmActivityType {
  DATA_REVIEW
  PROGRAM_ADJUSTMENT
  OUTCOME_ANALYSIS
  INTERACTIVE_COMMUNICATION
  OTHER
}

enum RtmInteractionType {
  IN_SESSION
  PHONE_CALL
  VIDEO_CALL
  OTHER
}

enum RtmMonitoringType {
  CBT
  MSK
  RESPIRATORY
}

enum RtmEnrollmentStatus {
  PENDING_CONSENT
  ACTIVE
  PAUSED
  ENDED
}

model RtmEngagementEvent {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  enrollmentId    String?
  enrollment      Enrollment?  @relation(fields: [enrollmentId], references: [id])
  eventType       RtmEventType
  eventDate       DateTime     @db.Date
  eventTimestamp   DateTime     @default(now())
  metadata        Json?
  createdAt       DateTime     @default(now())

  @@index([userId, eventDate])
  @@index([enrollmentId, eventDate])
  @@map("rtm_engagement_events")
}

model RtmEnrollment {
  id                 String              @id @default(cuid())
  clinicianId        String
  clinician          ClinicianProfile    @relation(fields: [clinicianId], references: [id])
  clientId           String
  client             User                @relation("RtmClient", fields: [clientId], references: [id])
  enrollmentId       String?
  enrollment         Enrollment?         @relation(fields: [enrollmentId], references: [id])
  monitoringType     RtmMonitoringType   @default(CBT)
  diagnosisCodes     Json
  payerName          String
  subscriberId       String
  groupNumber        String?
  consentSignedAt    DateTime?
  consentDocumentUrl String?
  status             RtmEnrollmentStatus @default(PENDING_CONSENT)
  startDate          DateTime            @db.Date
  endDate            DateTime?           @db.Date
  setupBilled        Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  billingPeriods RtmBillingPeriod[]

  @@index([clinicianId])
  @@index([clientId])
  @@map("rtm_enrollments")
}

model RtmBillingPeriod {
  id                           String             @id @default(cuid())
  rtmEnrollmentId              String
  rtmEnrollment                RtmEnrollment      @relation(fields: [rtmEnrollmentId], references: [id], onDelete: Cascade)
  clinicianId                  String
  clinician                    ClinicianProfile   @relation(fields: [clinicianId], references: [id])
  clientId                     String
  client                       User               @relation("RtmBillingClient", fields: [clientId], references: [id])
  enrollmentId                 String?
  enrollment                   Enrollment?        @relation(fields: [enrollmentId], references: [id])
  periodStart                  DateTime           @db.Date
  periodEnd                    DateTime           @db.Date
  engagementDays               Int                @default(0)
  clinicianMinutes             Int                @default(0)
  hasInteractiveCommunication  Boolean            @default(false)
  interactiveCommunicationDate DateTime?          @db.Date
  interactiveCommunicationType RtmInteractionType?
  status                       RtmPeriodStatus    @default(ACTIVE)
  billingTier                  RtmBillingTier     @default(NONE)
  eligibleCodes                Json               @default("[]")
  notes                        String?
  superbillUrl                 String?
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  timeLogs RtmClinicianTimeLog[]

  @@unique([rtmEnrollmentId, periodStart])
  @@index([clinicianId])
  @@index([clientId])
  @@index([status])
  @@map("rtm_billing_periods")
}

model RtmClinicianTimeLog {
  id                         String           @id @default(cuid())
  billingPeriodId            String
  billingPeriod              RtmBillingPeriod @relation(fields: [billingPeriodId], references: [id], onDelete: Cascade)
  clinicianId                String
  clinician                  ClinicianProfile @relation(fields: [clinicianId], references: [id])
  clientId                   String
  client                     User             @relation("RtmTimeLogClient", fields: [clientId], references: [id])
  activityType               RtmActivityType
  durationMinutes            Int
  description                String
  activityDate               DateTime         @db.Date
  isInteractiveCommunication Boolean          @default(false)
  createdAt                  DateTime         @default(now())

  @@index([billingPeriodId])
  @@index([clinicianId])
  @@map("rtm_clinician_time_logs")
}

model ClinicianBillingProfile {
  id                  String           @id @default(cuid())
  clinicianId         String           @unique
  clinician           ClinicianProfile @relation(fields: [clinicianId], references: [id])
  providerName        String
  credentials         String
  npiNumber           String
  taxId               String
  practiceName        String
  practiceAddress     String
  practiceCity        String
  practiceState       String
  practiceZip         String
  practicePhone       String
  licenseNumber       String
  licenseState        String
  placeOfServiceCode  String           @default("02")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("clinician_billing_profiles")
}

// ── Clinician & Client Configs ────────────────────────

model ClinicianConfig {
  id                   String       @id @default(cuid())
  clinicianId          String       @unique
  clinician            ClinicianProfile @relation(fields: [clinicianId], references: [id])
  providerType         ProviderType @default(OTHER)
  presetId             String?
  primaryModality      String?
  enabledModules       Json
  dashboardLayout      Json
  defaultTrackerPreset String?
  defaultAssessments   Json?
  practiceName         String?
  practiceLogoUrl      String?
  brandColor           String?
  setupCompleted       Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@map("clinician_configs")
}

model ClientConfig {
  id                  String   @id @default(cuid())
  clientId            String
  client              User     @relation("ClientConfigs", fields: [clientId], references: [id])
  clinicianId         String
  clinician           ClinicianProfile @relation("ClinicianClientConfigs", fields: [clinicianId], references: [id])
  enabledModules      Json?
  activeTrackers      Json?
  activeAssessments   Json?
  activeMedications   Json?
  customConfig        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([clientId, clinicianId])
  @@index([clinicianId])
  @@map("client_configs")
}

// ── Clinician-Client Relationship ─────────────────────

enum ClinicianClientStatus {
  INVITED
  ACTIVE
  PAUSED
  DISCHARGED
}

model ClinicianClient {
  id           String                @id @default(cuid())
  clinicianId  String
  clinician    ClinicianProfile      @relation(fields: [clinicianId], references: [id])
  clientId     String
  client       User                  @relation("ClinicianClientUser", fields: [clientId], references: [id])
  status       ClinicianClientStatus @default(INVITED)
  invitedAt    DateTime              @default(now())
  acceptedAt   DateTime?
  dischargedAt DateTime?
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([clinicianId, clientId])
  @@index([clinicianId])
  @@index([clientId])
  @@map("clinician_clients")
}

// ── Audit Trail (HIPAA) ───────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  action       AuditAction
  resourceType String
  resourceId   String
  metadata     Json?
  timestamp    DateTime    @default(now())

  @@index([userId])
  @@index([resourceType])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}
