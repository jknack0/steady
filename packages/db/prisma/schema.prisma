generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────

enum UserRole {
  CLINICIAN
  PARTICIPANT
  ADMIN
}

enum Cadence {
  WEEKLY
  BIWEEKLY
  SELF_PACED
}

enum EnrollmentMethod {
  INVITE
  LINK
  CODE
}

enum SessionType {
  ONE_ON_ONE
  GROUP
  SELF_PACED
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UnlockRule {
  SEQUENTIAL
  MANUAL
  TIME_BASED
}

enum PartType {
  TEXT
  VIDEO
  STRATEGY_CARDS
  JOURNAL_PROMPT
  CHECKLIST
  RESOURCE_LINK
  DIVIDER
  HOMEWORK
  ASSESSMENT
  INTAKE_FORM
  SMART_GOALS
  STYLED_CONTENT
  PDF
}

enum EnrollmentStatus {
  INVITED
  ACTIVE
  PAUSED
  COMPLETED
  DROPPED
}

enum ModuleProgressStatus {
  LOCKED
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

enum PartProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum TaskStatus {
  TODO
  DONE
  ARCHIVED
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum TaskSourceType {
  MANUAL
  HOMEWORK
  CLINICIAN_PUSH
  SESSION
}

enum EventType {
  TIME_BLOCK
  SESSION
  EXTERNAL_SYNC
  CATCH_UP
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationCategory {
  MORNING_CHECKIN
  HOMEWORK
  SESSION
  TASK
  WEEKLY_REVIEW
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  CUSTOM
}

enum TrackerFieldType {
  SCALE
  NUMBER
  YES_NO
  MULTI_CHECK
  FREE_TEXT
  TIME
  FEELINGS_WHEEL
}

enum HomeworkInstanceStatus {
  PENDING
  COMPLETED
  SKIPPED
  MISSED
}

enum StreakCategory {
  JOURNAL
  CHECKIN
  HOMEWORK
}

enum ProviderType {
  THERAPIST
  PSYCHIATRIST
  PSYCHOLOGIST
  COUNSELOR
  PSYCH_NP
  COACH
  OTHER
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  DENIED
  PAID
}

enum SubscriberRelationship {
  SELF
  SPOUSE
  CHILD
  OTHER
}

enum CheckoutSessionStatus {
  OPEN
  COMPLETED
  EXPIRED
}

// ── Practices ─────────────────────────────────────────

enum PracticeRole {
  OWNER
  CLINICIAN
}

model Practice {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stediApiKeyEncrypted String?
  stediApiKeyLastFour  String?

  stripeConnectedAccountId     String?
  stripeApiKeyEncrypted        String?
  stripeApiKeyLastFour         String?
  stripeWebhookSecretEncrypted String?

  memberships      PracticeMembership[]
  programs         Program[]            @relation("PracticePrograms")
  appointments     Appointment[]
  locations        Location[]
  serviceCodes     ServiceCode[]
  invoices         Invoice[]
  recurringSeries  RecurringSeries[]
  insuranceClaims  InsuranceClaim[]
  stripeCustomers  StripeCustomer[]
  checkoutSessions CheckoutSession[]

  @@map("practices")
}

model PracticeMembership {
  id           String       @id @default(cuid())
  practiceId   String
  practice     Practice     @relation(fields: [practiceId], references: [id])
  clinicianId  String
  clinician    ClinicianProfile @relation(fields: [clinicianId], references: [id])
  role         PracticeRole @default(CLINICIAN)
  joinedAt     DateTime     @default(now())

  @@unique([practiceId, clinicianId])
  @@index([practiceId])
  @@index([clinicianId])
  @@map("practice_memberships")
}

// ── Users & Auth ───────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  cognitoId    String?
  role         UserRole
  firstName    String
  lastName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pushToken    String?
  pushTokenUpdatedAt DateTime?

  clinicianProfile      ClinicianProfile?
  participantProfile    ParticipantProfile?
  notificationPreferences NotificationPreference[]

  rtmEngagementEvents  RtmEngagementEvent[]
  rtmEnrollmentsAsClient RtmEnrollment[]      @relation("RtmClient")
  rtmBillingPeriodsAsClient RtmBillingPeriod[] @relation("RtmBillingClient")
  rtmTimeLogsAsClient  RtmClinicianTimeLog[]  @relation("RtmTimeLogClient")
  clientConfigs        ClientConfig[]         @relation("ClientConfigs")
  clinicianClients     ClinicianClient[]      @relation("ClinicianClientUser")
  acceptedInvitations  PatientInvitation[]    @relation("InvitationAcceptedBy")
  createdAppointments  Appointment[]          @relation("AppointmentCreatedBy")
  createdRecurringSeries RecurringSeries[]    @relation("RecurringSeriesCreatedBy")
  streakRecords        StreakRecord[]

  @@map("users")
}

model ClinicianProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
  practiceName String?
  licenseType  String?
  bio          String?
  timezone     String  @default("America/New_York")

  programs    Program[]
  memberships PracticeMembership[]

  rtmEnrollments    RtmEnrollment[]
  rtmBillingPeriods RtmBillingPeriod[]
  rtmTimeLogs       RtmClinicianTimeLog[]
  billingProfile    ClinicianBillingProfile?
  config            ClinicianConfig?
  clientConfigs     ClientConfig[]   @relation("ClinicianClientConfigs")
  clients           ClinicianClient[]
  appointments      Appointment[]
  invitations       PatientInvitation[]
  invoices          Invoice[]
  recurringSeries   RecurringSeries[]
  insuranceClaims   InsuranceClaim[]

  @@map("clinician_profiles")
}

model ParticipantProfile {
  id                   String  @id @default(cuid())
  userId               String  @unique
  user                 User    @relation(fields: [userId], references: [id])
  timezone             String    @default("America/New_York")
  onboardingCompleted  Boolean   @default(false)

  // Patient demographics (CMS-1500 Box 3 & Box 5)
  dateOfBirth          DateTime?
  gender               String?   // M, F, U
  addressStreet        String?
  addressCity          String?
  addressState         String?
  addressZip           String?

  enrollments       Enrollment[]
  tasks             Task[]
  calendarEvents    CalendarEvent[]
  journalEntries    JournalEntry[]
  dailyTrackers     DailyTracker[]
  homeworkInstances HomeworkInstance[]
  appointments      Appointment[]
  sessionReviews    SessionReview[]
  invoices          Invoice[]
  recurringSeries   RecurringSeries[]
  patientInsurance  PatientInsurance?
  insuranceClaims   InsuranceClaim[]
  stripeCustomers   StripeCustomer[]

  @@map("participant_profiles")
}

// ── Programs & Content ─────────────────────────────────

model Program {
  id               String           @id @default(cuid())
  clinicianId      String
  clinician        ClinicianProfile @relation(fields: [clinicianId], references: [id])
  practiceId       String?
  practice         Practice?        @relation("PracticePrograms", fields: [practiceId], references: [id])
  title            String
  description      String?
  category         String?
  durationWeeks    Int?
  coverImageUrl    String?
  cadence          Cadence          @default(WEEKLY)
  enrollmentMethod EnrollmentMethod @default(INVITE)
  enrollmentCode   String?          @unique
  sessionType      SessionType      @default(ONE_ON_ONE)
  followUpCount    Int              @default(0)
  isTemplate       Boolean          @default(false)
  templateSourceId String?
  templateSource   Program?         @relation("ProgramTemplate", fields: [templateSourceId], references: [id])
  clones           Program[]        @relation("ProgramTemplate")
  status           ProgramStatus    @default(DRAFT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  modules        Module[]
  enrollments    Enrollment[]
  dailyTrackers  DailyTracker[]
  invitations    PatientInvitation[]
  reviewTemplate ReviewTemplate?

  @@index([practiceId])
  @@map("programs")
}

model Module {
  id               String     @id @default(cuid())
  programId        String
  program          Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  title            String
  subtitle         String?
  summary          String?
  estimatedMinutes Int?
  sortOrder        Int
  unlockRule       UnlockRule @default(SEQUENTIAL)
  unlockDelayDays  Int?
  deletedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  parts           Part[]
  moduleProgress  ModuleProgress[]
  currentEnrollments Enrollment[] @relation("CurrentModule")
  completedSessions  Session[]    @relation("CompletedModule")
  enrollmentOverrides EnrollmentOverride[]

  @@map("modules")
}

model Part {
  id         String   @id @default(cuid())
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type       PartType
  title      String
  sortOrder  Int
  isRequired Boolean  @default(true)
  content    Json
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  partProgress        PartProgress[]
  journalEntries      JournalEntry[] @relation("PromptPart")
  homeworkInstances   HomeworkInstance[]
  enrollmentOverrides EnrollmentOverride[]

  @@map("parts")
}

// ── Enrollment & Progress ──────────────────────────────

model Enrollment {
  id              String           @id @default(cuid())
  participantId   String
  participant     ParticipantProfile @relation(fields: [participantId], references: [id])
  programId       String
  program         Program          @relation(fields: [programId], references: [id])
  status          EnrollmentStatus @default(INVITED)
  currentModuleId String?
  currentModule   Module?          @relation("CurrentModule", fields: [currentModuleId], references: [id])
  enrolledAt      DateTime         @default(now())
  completedAt     DateTime?

  moduleProgress      ModuleProgress[]
  partProgress        PartProgress[]
  sessions            Session[]
  homeworkInstances   HomeworkInstance[]
  dailyTrackers       DailyTracker[]
  rtmEngagementEvents RtmEngagementEvent[]
  rtmEnrollments      RtmEnrollment[]
  rtmBillingPeriods   RtmBillingPeriod[]
  sessionReviews      SessionReview[]
  enrollmentOverrides EnrollmentOverride[]

  @@map("enrollments")
}

model ModuleProgress {
  id           String               @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment           @relation(fields: [enrollmentId], references: [id])
  moduleId     String
  module       Module               @relation(fields: [moduleId], references: [id])
  status       ModuleProgressStatus @default(LOCKED)
  unlockedAt   DateTime?
  completedAt  DateTime?
  customUnlock Boolean              @default(false)

  @@unique([enrollmentId, moduleId])
  @@index([enrollmentId])
  @@map("module_progress")
}

model PartProgress {
  id           String             @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment         @relation(fields: [enrollmentId], references: [id])
  partId       String
  part         Part               @relation(fields: [partId], references: [id], onDelete: Cascade)
  status       PartProgressStatus @default(NOT_STARTED)
  completedAt  DateTime?
  responseData Json?

  @@unique([enrollmentId, partId])
  @@index([enrollmentId])
  @@map("part_progress")
}

// ── Steady System ──────────────────────────────────────

model Task {
  id               String          @id @default(cuid())
  participantId    String
  participant      ParticipantProfile @relation(fields: [participantId], references: [id])
  title            String
  description      String?
  estimatedMinutes Int?
  dueDate          DateTime?
  energyLevel      EnergyLevel?
  category         String?
  isRecurring      Boolean         @default(false)
  recurrenceRule   Json?
  status           TaskStatus      @default(TODO)
  completedAt      DateTime?
  sourceType       TaskSourceType?
  sourceId         String?
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  calendarEvents CalendarEvent[]

  @@index([participantId])
  @@map("tasks")
}

model CalendarEvent {
  id                 String    @id @default(cuid())
  participantId      String
  participant        ParticipantProfile @relation(fields: [participantId], references: [id])
  title              String
  startTime          DateTime
  endTime            DateTime
  taskId             String?
  task               Task?     @relation(fields: [taskId], references: [id])
  eventType          EventType
  color              String?
  externalCalendarId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("calendar_events")
}

model JournalEntry {
  id                    String              @id @default(cuid())
  participantId         String
  participant           ParticipantProfile  @relation(fields: [participantId], references: [id])
  entryDate             DateTime            @db.Date
  promptPartId          String?
  promptPart            Part?               @relation("PromptPart", fields: [promptPartId], references: [id])
  responses             Json?
  freeformContent       String?
  regulationScore       Int?
  isSharedWithClinician Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([participantId, entryDate])
  @@map("journal_entries")
}

// ── Sessions ───────────────────────────────────────────

model Session {
  id                 String        @id @default(cuid())
  enrollmentId       String
  enrollment         Enrollment    @relation(fields: [enrollmentId], references: [id])
  scheduledAt        DateTime
  videoCallUrl       String?
  status             SessionStatus @default(SCHEDULED)
  clinicianNotes     String?
  participantSummary String?
  moduleCompletedId  String?
  moduleCompleted    Module?       @relation("CompletedModule", fields: [moduleCompletedId], references: [id])
  appointmentId      String?
  appointment        Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([scheduledAt])
  @@index([appointmentId])
  @@map("sessions")
}

// ── Appointments (Sprint 19) ───────────────────────────

enum OverrideType {
  HIDE_HOMEWORK_ITEM
  ADD_HOMEWORK_ITEM
  ADD_RESOURCE
  CLINICIAN_NOTE
}

enum AppointmentStatus {
  SCHEDULED
  ATTENDED
  NO_SHOW
  LATE_CANCELED
  CLIENT_CANCELED
  CLINICIAN_CANCELED
}

enum AppointmentType {
  INDIVIDUAL
  COUPLE
  GROUP
}

enum LocationType {
  IN_PERSON
  VIRTUAL
}

enum RecurrenceRule {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum ReminderType {
  EMAIL
  PUSH
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model Appointment {
  id               String            @id @default(cuid())
  practiceId       String
  practice         Practice          @relation(fields: [practiceId], references: [id])
  clinicianId      String
  clinician        ClinicianProfile  @relation(fields: [clinicianId], references: [id])
  participantId    String
  participant      ParticipantProfile @relation(fields: [participantId], references: [id])
  serviceCodeId    String
  serviceCode      ServiceCode       @relation(fields: [serviceCodeId], references: [id])
  locationId       String
  location         Location          @relation(fields: [locationId], references: [id])
  startAt          DateTime
  endAt            DateTime
  status           AppointmentStatus @default(SCHEDULED)
  appointmentType  AppointmentType   @default(INDIVIDUAL)
  internalNote     String?
  cancelReason     String?
  statusChangedAt  DateTime?
  recurringSeriesId String?
  recurringSeries   RecurringSeries?  @relation(fields: [recurringSeriesId], references: [id], onDelete: SetNull)
  createdById      String
  createdBy        User              @relation("AppointmentCreatedBy", fields: [createdById], references: [id])
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  sessions           Session[]
  sessionReviews     SessionReview[]
  invoiceLineItems   InvoiceLineItem[]
  reminders          AppointmentReminder[]
  insuranceClaim     InsuranceClaim?
  telehealthSession  TelehealthSession?

  @@index([practiceId, clinicianId, startAt])
  @@index([practiceId, locationId, startAt])
  @@index([practiceId, participantId])
  @@index([status])
  @@index([createdById])
  @@index([recurringSeriesId])
  @@map("appointments")
}

// ── Telehealth Sessions ─────────────────────────────────

enum TelehealthSessionStatus {
  WAITING
  ACTIVE
  ENDED
}

model TelehealthSession {
  id                  String                  @id @default(cuid())
  appointmentId       String                  @unique
  appointment         Appointment             @relation(fields: [appointmentId], references: [id])
  roomName            String                  @unique
  status              TelehealthSessionStatus @default(WAITING)
  clinicianJoinedAt   DateTime?
  participantJoinedAt DateTime?
  endedAt             DateTime?
  durationSeconds     Int?
  endedBy             String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([status])
  @@index([roomName])
  @@map("telehealth_sessions")
}

model Location {
  id           String        @id @default(cuid())
  practiceId   String
  practice     Practice      @relation(fields: [practiceId], references: [id])
  name         String
  type         LocationType
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  timezone     String?
  isDefault    Boolean       @default(false)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments    Appointment[]
  recurringSeries RecurringSeries[]

  @@index([practiceId, isActive])
  @@map("locations")
}

model ServiceCode {
  id                     String        @id @default(cuid())
  practiceId             String
  practice               Practice      @relation(fields: [practiceId], references: [id])
  code                   String
  description            String
  defaultDurationMinutes Int
  defaultPriceCents      Int?
  isActive               Boolean       @default(true)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  appointments     Appointment[]
  invoiceLineItems InvoiceLineItem[]
  recurringSeries  RecurringSeries[]

  @@unique([practiceId, code])
  @@index([practiceId, isActive])
  @@map("service_codes")
}

// ── Appointment Reminders ────────────────────────────────

model AppointmentReminder {
  id            String         @id @default(cuid())
  appointmentId String
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  type          ReminderType   @default(PUSH)
  scheduledFor  DateTime
  sentAt        DateTime?
  status        ReminderStatus @default(PENDING)
  createdAt     DateTime       @default(now())

  @@index([status, scheduledFor])
  @@index([appointmentId])
  @@map("appointment_reminders")
}

// ── Billing & Invoicing ──────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  CASH
  CHECK
  CREDIT_CARD
  INSURANCE
  OTHER
}

model Invoice {
  id            String        @id @default(cuid())
  practiceId    String
  practice      Practice      @relation(fields: [practiceId], references: [id])
  clinicianId   String
  clinician     ClinicianProfile @relation(fields: [clinicianId], references: [id])
  participantId String
  participant   ParticipantProfile @relation(fields: [participantId], references: [id])
  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime?
  dueAt         DateTime?
  subtotalCents Int
  taxCents      Int           @default(0)
  totalCents    Int
  paidCents     Int           @default(0)
  notes         String?
  diagnosisCodes String[]    @default([])

  paymentLinkUrl             String?
  paymentLinkExpiresAt       DateTime?
  balanceDueSourceInvoiceId  String?
  balanceDueSourceInvoice    Invoice?  @relation("BalanceDueSource", fields: [balanceDueSourceInvoiceId], references: [id])
  balanceDueInvoices         Invoice[] @relation("BalanceDueSource")

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems        InvoiceLineItem[]
  payments         Payment[]
  checkoutSessions CheckoutSession[]

  @@unique([practiceId, invoiceNumber])
  @@index([practiceId, participantId])
  @@index([practiceId, status])
  @@map("invoices")
}

model InvoiceLineItem {
  id             String       @id @default(cuid())
  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  serviceCodeId  String
  serviceCode    ServiceCode  @relation(fields: [serviceCodeId], references: [id])
  description        String
  unitPriceCents     Int
  quantity           Int          @default(1)
  totalCents         Int
  dateOfService      DateTime?
  placeOfServiceCode String?
  modifiers          String[]     @default([])
  createdAt          DateTime     @default(now())

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amountCents Int
  method      PaymentMethod
  reference   String?
  receivedAt  DateTime
  stripePaymentIntentId String? @unique
  createdAt   DateTime      @default(now())

  @@index([invoiceId])
  @@map("payments")
}

// ── Insurance Billing (Stedi) ───────────────────────────

model PatientInsurance {
  id                        String                  @id @default(cuid())
  participantId             String                  @unique
  participant               ParticipantProfile      @relation(fields: [participantId], references: [id])
  payerId                   String
  payerName                 String
  subscriberId              String
  groupNumber               String?
  relationshipToSubscriber  SubscriberRelationship  @default(SELF)
  policyHolderFirstName     String?
  policyHolderLastName      String?
  policyHolderDob           String?
  policyHolderGender        String?
  isActive                  Boolean                 @default(true)
  cachedEligibility         Json?
  eligibilityCheckedAt      DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  claims InsuranceClaim[]

  @@index([participantId])
  @@map("patient_insurance")
}

model InsuranceClaim {
  id                    String            @id @default(cuid())
  practiceId            String
  practice              Practice          @relation(fields: [practiceId], references: [id])
  clinicianId           String
  clinician             ClinicianProfile  @relation(fields: [clinicianId], references: [id])
  participantId         String
  participant           ParticipantProfile @relation(fields: [participantId], references: [id])
  appointmentId         String            @unique
  appointment           Appointment       @relation(fields: [appointmentId], references: [id])
  patientInsuranceId    String
  patientInsurance      PatientInsurance   @relation(fields: [patientInsuranceId], references: [id])
  status                ClaimStatus       @default(DRAFT)
  stediTransactionId    String?
  stediIdempotencyKey   String            @default(cuid())
  serviceCode           String
  modifiers             String[]          @default([])
  servicePriceCents     Int
  placeOfServiceCode    String
  dateOfService         DateTime
  diagnosisCodes        String[]
  submittedAt           DateTime?
  respondedAt           DateTime?
  rejectionReason       String?
  retentionExpiresAt    DateTime?
  retryCount            Int               @default(0)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  statusHistory ClaimStatusHistory[]

  @@index([practiceId, status])
  @@index([practiceId, clinicianId])
  @@index([appointmentId])
  @@map("insurance_claims")
}

model ClaimStatusHistory {
  id         String       @id @default(cuid())
  claimId    String
  claim      InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  fromStatus ClaimStatus?
  toStatus   ClaimStatus
  changedBy  String
  reason     String?
  createdAt  DateTime     @default(now())

  @@index([claimId])
  @@map("claim_status_history")
}

model DiagnosisCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  category    String
  isCommon    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([category, isCommon])
  @@map("diagnosis_codes")
}

// ── Stripe Payment Integration ──────────────────────────

model StripeCustomer {
  id               String              @id @default(cuid())
  practiceId       String
  practice         Practice            @relation(fields: [practiceId], references: [id])
  participantId    String
  participant      ParticipantProfile  @relation(fields: [participantId], references: [id])
  stripeCustomerId String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  savedPaymentMethods SavedPaymentMethod[]

  @@unique([practiceId, participantId])
  @@unique([practiceId, stripeCustomerId])
  @@index([participantId])
  @@map("stripe_customers")
}

model SavedPaymentMethod {
  id                    String         @id @default(cuid())
  stripeCustomerId      String
  stripeCustomer        StripeCustomer @relation(fields: [stripeCustomerId], references: [id], onDelete: Cascade)
  stripePaymentMethodId String         @unique
  cardBrand             String
  cardLastFour          String
  expiryMonth           Int
  expiryYear            Int
  isDefault             Boolean        @default(false)
  createdAt             DateTime       @default(now())

  @@index([stripeCustomerId])
  @@map("saved_payment_methods")
}

model CheckoutSession {
  id                    String                @id @default(cuid())
  invoiceId             String
  invoice               Invoice               @relation(fields: [invoiceId], references: [id])
  practiceId            String
  practice              Practice              @relation(fields: [practiceId], references: [id])
  stripeSessionId       String                @unique
  stripePaymentIntentId String?
  status                CheckoutSessionStatus @default(OPEN)
  expiresAt             DateTime
  createdAt             DateTime              @default(now())

  @@index([invoiceId])
  @@index([status, expiresAt])
  @@map("checkout_sessions")
}

// ── Streaks (Sprint 15) ──────────────────────────────────

model StreakRecord {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  category       StreakCategory
  currentStreak  Int            @default(0)
  longestStreak  Int            @default(0)
  lastActiveDate DateTime?      @db.Date
  gapDaysUsed    Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, category])
  @@index([userId])
  @@map("streak_records")
}

// ── Notifications ──────────────────────────────────────

model NotificationPreference {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  category       NotificationCategory
  enabled        Boolean              @default(true)
  preferredTime  String?
  customSettings Json?

  @@unique([userId, category])
  @@map("notification_preferences")
}

// ── Homework Instances (Recurring) ────────────────────

model HomeworkInstance {
  id            String                 @id @default(cuid())
  partId        String?
  part          Part?                  @relation(fields: [partId], references: [id], onDelete: Cascade)
  enrollmentId  String?
  enrollment    Enrollment?            @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  participantId String?
  participant   ParticipantProfile?    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  title         String?
  content       Json?
  dueDate       DateTime               @db.Date
  status        HomeworkInstanceStatus  @default(PENDING)
  completedAt   DateTime?
  response      Json?
  createdAt     DateTime               @default(now())
  createdById   String?

  @@unique([partId, enrollmentId, dueDate])
  @@index([enrollmentId])
  @@index([partId])
  @@index([participantId])
  @@index([dueDate])
  @@map("homework_instances")
}

// ── Daily Trackers ────────────────────────────────────

model DailyTracker {
  id            String              @id @default(cuid())
  programId     String?
  program       Program?            @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrollmentId  String?
  enrollment    Enrollment?         @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  participantId String?
  participant   ParticipantProfile? @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdById   String
  name          String
  description   String?
  reminderTime  String              @default("20:00")
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  fields  DailyTrackerField[]
  entries DailyTrackerEntry[]

  @@index([programId])
  @@index([enrollmentId])
  @@index([participantId])
  @@map("daily_trackers")
}

model DailyTrackerField {
  id         String           @id @default(cuid())
  trackerId  String
  tracker    DailyTracker     @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  label      String
  fieldType  TrackerFieldType
  options    Json?
  sortOrder  Int
  isRequired Boolean          @default(true)

  @@index([trackerId])
  @@map("daily_tracker_fields")
}

model DailyTrackerEntry {
  id          String       @id @default(cuid())
  trackerId   String
  tracker     DailyTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  userId      String
  date        DateTime     @db.Date
  responses   Json
  completedAt DateTime
  createdAt   DateTime     @default(now())

  @@unique([trackerId, userId, date])
  @@index([trackerId])
  @@index([userId])
  @@index([date])
  @@map("daily_tracker_entries")
}

// ── RTM (Remote Therapeutic Monitoring) ──────────────

enum RtmEventType {
  DAILY_TRACKER_COMPLETED
  HOMEWORK_COMPLETED
  ASSESSMENT_COMPLETED
  STRATEGY_CARD_VIEWED
  JOURNAL_ENTRY_CREATED
  RESOURCE_VIEWED
  APP_OPENED
  MESSAGE_SENT
}

enum RtmPeriodStatus {
  ACTIVE
  THRESHOLD_MET
  BILLED
  EXPIRED
}

enum RtmBillingTier {
  NONE
  SHORT_PERIOD
  FULL_PERIOD
}

enum RtmActivityType {
  DATA_REVIEW
  PROGRAM_ADJUSTMENT
  OUTCOME_ANALYSIS
  INTERACTIVE_COMMUNICATION
  OTHER
}

enum RtmInteractionType {
  IN_SESSION
  PHONE_CALL
  VIDEO_CALL
  OTHER
}

enum RtmMonitoringType {
  CBT
  MSK
  RESPIRATORY
}

enum RtmEnrollmentStatus {
  PENDING_CONSENT
  ACTIVE
  PAUSED
  ENDED
}

model RtmEngagementEvent {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  enrollmentId    String?
  enrollment      Enrollment?  @relation(fields: [enrollmentId], references: [id])
  eventType       RtmEventType
  eventDate       DateTime     @db.Date
  eventTimestamp   DateTime     @default(now())
  metadata        Json?
  createdAt       DateTime     @default(now())

  @@index([userId, eventDate])
  @@index([enrollmentId, eventDate])
  @@map("rtm_engagement_events")
}

model RtmEnrollment {
  id                 String              @id @default(cuid())
  clinicianId        String
  clinician          ClinicianProfile    @relation(fields: [clinicianId], references: [id])
  clientId           String
  client             User                @relation("RtmClient", fields: [clientId], references: [id])
  enrollmentId       String?
  enrollment         Enrollment?         @relation(fields: [enrollmentId], references: [id])
  monitoringType     RtmMonitoringType   @default(CBT)
  diagnosisCodes     Json
  payerName          String
  subscriberId       String
  groupNumber        String?
  consentSignedAt    DateTime?
  consentDocumentUrl String?
  status             RtmEnrollmentStatus @default(PENDING_CONSENT)
  startDate          DateTime            @db.Date
  endDate            DateTime?           @db.Date
  setupBilled        Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  billingPeriods RtmBillingPeriod[]

  @@index([clinicianId])
  @@index([clientId])
  @@map("rtm_enrollments")
}

model RtmBillingPeriod {
  id                           String             @id @default(cuid())
  rtmEnrollmentId              String
  rtmEnrollment                RtmEnrollment      @relation(fields: [rtmEnrollmentId], references: [id], onDelete: Cascade)
  clinicianId                  String
  clinician                    ClinicianProfile   @relation(fields: [clinicianId], references: [id])
  clientId                     String
  client                       User               @relation("RtmBillingClient", fields: [clientId], references: [id])
  enrollmentId                 String?
  enrollment                   Enrollment?        @relation(fields: [enrollmentId], references: [id])
  periodStart                  DateTime           @db.Date
  periodEnd                    DateTime           @db.Date
  engagementDays               Int                @default(0)
  clinicianMinutes             Int                @default(0)
  hasInteractiveCommunication  Boolean            @default(false)
  interactiveCommunicationDate DateTime?          @db.Date
  interactiveCommunicationType RtmInteractionType?
  status                       RtmPeriodStatus    @default(ACTIVE)
  billingTier                  RtmBillingTier     @default(NONE)
  eligibleCodes                Json               @default("[]")
  notes                        String?
  superbillUrl                 String?
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  timeLogs RtmClinicianTimeLog[]

  @@unique([rtmEnrollmentId, periodStart])
  @@index([clinicianId])
  @@index([clientId])
  @@index([status])
  @@map("rtm_billing_periods")
}

model RtmClinicianTimeLog {
  id                         String           @id @default(cuid())
  billingPeriodId            String
  billingPeriod              RtmBillingPeriod @relation(fields: [billingPeriodId], references: [id], onDelete: Cascade)
  clinicianId                String
  clinician                  ClinicianProfile @relation(fields: [clinicianId], references: [id])
  clientId                   String
  client                     User             @relation("RtmTimeLogClient", fields: [clientId], references: [id])
  activityType               RtmActivityType
  durationMinutes            Int
  description                String
  activityDate               DateTime         @db.Date
  isInteractiveCommunication Boolean          @default(false)
  createdAt                  DateTime         @default(now())

  @@index([billingPeriodId])
  @@index([clinicianId])
  @@map("rtm_clinician_time_logs")
}

model ClinicianBillingProfile {
  id                  String           @id @default(cuid())
  clinicianId         String           @unique
  clinician           ClinicianProfile @relation(fields: [clinicianId], references: [id])
  providerName        String
  credentials         String
  npiNumber           String
  taxId               String
  practiceName        String
  practiceAddress     String
  practiceCity        String
  practiceState       String
  practiceZip         String
  practicePhone       String
  licenseNumber       String
  licenseState        String
  placeOfServiceCode  String           @default("02")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("clinician_billing_profiles")
}

// ── Clinician & Client Configs ────────────────────────

model ClinicianConfig {
  id                   String       @id @default(cuid())
  clinicianId          String       @unique
  clinician            ClinicianProfile @relation(fields: [clinicianId], references: [id])
  providerType         ProviderType @default(OTHER)
  presetId             String?
  primaryModality      String?
  enabledModules       Json
  dashboardLayout      Json
  clientOverviewLayout Json?
  defaultTrackerPreset String?
  defaultAssessments   Json?
  practiceName         String?
  practiceLogoUrl      String?
  brandColor           String?
  homeworkLabels       Json?
  reminderSettings     Json?
  setupCompleted       Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@map("clinician_configs")
}

model ClientConfig {
  id                  String   @id @default(cuid())
  clientId            String
  client              User     @relation("ClientConfigs", fields: [clientId], references: [id])
  clinicianId         String
  clinician           ClinicianProfile @relation("ClinicianClientConfigs", fields: [clinicianId], references: [id])
  enabledModules      Json?
  activeTrackers      Json?
  activeAssessments   Json?
  activeMedications   Json?
  customConfig        Json?
  clientOverviewLayout Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([clientId, clinicianId])
  @@index([clinicianId])
  @@map("client_configs")
}

// ── Clinician-Client Relationship ─────────────────────

enum ClinicianClientStatus {
  INVITED
  ACTIVE
  PAUSED
  DISCHARGED
}

model ClinicianClient {
  id           String                @id @default(cuid())
  clinicianId  String
  clinician    ClinicianProfile      @relation(fields: [clinicianId], references: [id])
  clientId     String
  client       User                  @relation("ClinicianClientUser", fields: [clientId], references: [id])
  status       ClinicianClientStatus @default(INVITED)
  invitedAt    DateTime              @default(now())
  acceptedAt   DateTime?
  dischargedAt DateTime?
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([clinicianId, clientId])
  @@index([clinicianId])
  @@index([clientId])
  @@map("clinician_clients")
}

// ── Patient Invitations ──────────────────────────────

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model PatientInvitation {
  id               String           @id @default(cuid())
  clinicianId      String
  clinician        ClinicianProfile @relation(fields: [clinicianId], references: [id])
  code             String           @unique
  patientName      String
  patientEmail     String
  patientEmailHash String
  programId        String?
  program          Program?         @relation(fields: [programId], references: [id])
  status           InvitationStatus @default(PENDING)
  emailSent        Boolean          @default(false)
  emailSendCount   Int              @default(0)
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  acceptedByUser   User?            @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id])
  revokedAt        DateTime?
  piiScrubbed      Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([clinicianId])
  @@index([patientEmailHash, clinicianId])
  @@index([status, expiresAt])
  @@map("patient_invitations")
}

// ── Audit Trail (HIPAA) ───────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  action       AuditAction
  resourceType String
  resourceId   String
  metadata     Json?
  timestamp    DateTime    @default(now())

  @@index([userId])
  @@index([resourceType])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}

// ── Refresh Tokens ──────────────────────────────────────

// RefreshToken model removed — Cognito handles token lifecycle

// ── Review & Session Prep (Sprint 14) ────────────────

model ReviewTemplate {
  id        String   @id @default(cuid())
  programId String   @unique
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  questions Json
  barriers  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("review_templates")
}

model SessionReview {
  id            String             @id @default(cuid())
  appointmentId String
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  enrollmentId  String
  enrollment    Enrollment         @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  participantId String
  participant   ParticipantProfile @relation(fields: [participantId], references: [id])
  responses     Json
  barriers      String[]
  submittedAt   DateTime
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([appointmentId, enrollmentId])
  @@index([appointmentId])
  @@index([participantId])
  @@map("session_reviews")
}

model EnrollmentOverride {
  id           String       @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  overrideType OverrideType
  moduleId     String?
  module       Module?      @relation(fields: [moduleId], references: [id])
  targetPartId String?
  targetPart   Part?        @relation(fields: [targetPartId], references: [id])
  payload      Json
  createdById  String
  createdAt    DateTime     @default(now())

  @@index([enrollmentId, moduleId])
  @@index([enrollmentId])
  @@map("enrollment_overrides")
}

// ── Recurring Appointments ───────────────────────────

model RecurringSeries {
  id              String            @id @default(cuid())
  practiceId      String
  practice        Practice          @relation(fields: [practiceId], references: [id])
  clinicianId     String
  clinician       ClinicianProfile  @relation(fields: [clinicianId], references: [id])
  participantId   String
  participant     ParticipantProfile @relation(fields: [participantId], references: [id])
  serviceCodeId   String
  serviceCode     ServiceCode       @relation(fields: [serviceCodeId], references: [id])
  locationId      String
  location        Location          @relation(fields: [locationId], references: [id])
  appointmentType AppointmentType   @default(INDIVIDUAL)
  internalNote    String?
  recurrenceRule  RecurrenceRule
  dayOfWeek       Int
  startTime       String
  endTime         String
  seriesStartDate DateTime
  seriesEndDate   DateTime?
  isActive        Boolean           @default(true)
  createdById     String
  createdBy       User              @relation("RecurringSeriesCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  appointments    Appointment[]

  @@index([practiceId, clinicianId, isActive])
  @@index([practiceId, participantId])
  @@map("recurring_series")
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("waitlist_entries")
}
