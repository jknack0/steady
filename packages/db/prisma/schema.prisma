generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLINICIAN
  PARTICIPANT
  ADMIN
}

enum ParticipantStatus {
  ENROLLED
  ACTIVE
  COMPLETED
  WITHDRAWN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String
  lastName  String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
