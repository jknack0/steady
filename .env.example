# Database
DATABASE_URL="postgresql://steady:steady_password@localhost:5432/steady_adhd?schema=public"

# Next.js
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# API
API_PORT=4000

# Field-level encryption (AES-256-GCM for Stedi API keys, patient insurance data)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY="your-32-byte-base64-key"

# S3 — local dev uses MinIO via AWS_ENDPOINT_URL
# In prod, leave AWS_ENDPOINT_URL unset to use real AWS S3
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_DEFAULT_REGION="us-east-2"
AWS_ENDPOINT_URL="http://localhost:9000"
AWS_S3_BUCKET_NAME="steady-dev"

# LiveKit (telehealth video)
LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret"
NEXT_PUBLIC_LIVEKIT_URL="ws://localhost:7880"

# Transcription pipeline
# Leave TRANSCRIPTION_QUEUE_URL unset in dev to use pg-boss instead of SQS
TRANSCRIPTION_QUEUE_URL=""
INTERNAL_API_KEY="dev-internal-key"
TRANSCRIPTION_WORKER_URL="http://localhost:8000"
