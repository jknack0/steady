# Database
DATABASE_URL="postgresql://steady:steady_password@localhost:5432/steady_adhd?schema=public"

# Next.js
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# API
API_PORT=4000

# Field-level encryption (AES-256-GCM for Stedi API keys, patient insurance data)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY="your-32-byte-base64-key"

# S3 (file uploads — HIPAA: encryption at rest, HTTPS-only, no public URLs)
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET="steady-uploads"

# LiveKit (telehealth video)
LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret"
NEXT_PUBLIC_LIVEKIT_URL="ws://localhost:7880"
