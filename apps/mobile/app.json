{
  "expo": {
    "name": "Steady with ADHD",
    "slug": "steady-with-adhd",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "steady",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#5B8A8A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.steady.adhd",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5B8A8A"
      },
      "package": "com.steady.adhd"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": ""
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#5B8A8A"
        }
      ],
      "expo-font"
    ]
  }
}
